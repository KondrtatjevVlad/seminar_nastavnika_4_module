    {
      "text": "%spark.pyspark\r\n\r\nwindow_city = Window.partitionBy(\"city\").orderBy(F.desc(\"revenue_sum\"))\r\n\r\nmart_city_top_products = (\r\n    city_product_metrics\r\n    .withColumn(\r\n        \"rank\",\r\n        F.row_number().over(window_city)\r\n    )\r\n    .filter(F.col(\"rank\") <= 2)\r\n    .select(\r\n        \"city\",\r\n        \"rank\",\r\n        \"product_id\",\r\n        \"product_name\",\r\n        \"orders_cnt\",\r\n        \"qty_sum\",\r\n        \"revenue_sum\"\r\n    )\r\n)\r\n\r\nmart_city_top_products.orderBy(\"city\", \"rank\").show()",
