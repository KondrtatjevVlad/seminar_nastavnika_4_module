    {
      "text": "%spark.pyspark\r\n\r\ncity_product_metrics = (\r\n    orders_enriched\r\n    .groupBy(\"city\", \"product_id\", \"product_name\")\r\n    .agg(\r\n        F.count(\"order_id\").alias(\"orders_cnt\"),\r\n        F.sum(\"qty\").alias(\"qty_sum\"),\r\n        F.sum(\"revenue\").alias(\"revenue_sum\")\r\n    )\r\n)\r\n\r\ncity_product_metrics.show()",
